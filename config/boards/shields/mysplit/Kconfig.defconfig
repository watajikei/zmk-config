if SHIELD_MYSPLIT_LEFT

config ZMK_KEYBOARD_NAME
    default "MySplit"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif # SHIELD_MYSPLIT_LEFT

if SHIELD_MYSPLIT_LEFT || SHIELD_MYSPLIT_RIGHT

config ZMK_SPLIT
    default y

# Some Windows Bluetooth chipsets (Realtek/Intel) fail to pair when
# the 2Mbps PHY is advertised. Disabling it is a known workaround.
config BT_CTLR_PHY_2M
    default n

# Windows requires authenticated (MITM) pairing for BLE keyboards.
config ZMK_BLE_PASSKEY_ENTRY
    default y

endif # SHIELD_MYSPLIT_LEFT || SHIELD_MYSPLIT_RIGHT
