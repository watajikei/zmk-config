#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        rows = <4>;
        columns = <11>;

        map = <
        /* 左手側（6列×3行） */                       /* 右手側（5列×3行） */
        RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)    RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
        RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
                                RC(3,4) RC(3,5)    RC(3,6) RC(3,7)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
    };

    layouts {
        compatible = "zmk,physical-layouts";
        default_layout: default_layout {
            compatible = "zmk,physical-layout";
            display-name = "Default Layout";
            transform = <&default_transform>;
            kscan-map = <
                /* 左手側 メイン */
                <&kscan0 0 0   0   0> <&kscan0 0 1 100   0> <&kscan0 0 2 200   0> <&kscan0 0 3 300   0> <&kscan0 0 4 400   0> <&kscan0 0 5 500   0>
                <&kscan0 1 0   0 100> <&kscan0 1 1 100 100> <&kscan0 1 2 200 100> <&kscan0 1 3 300 100> <&kscan0 1 4 400 100> <&kscan0 1 5 500 100>
                <&kscan0 2 0   0 200> <&kscan0 2 1 100 200> <&kscan0 2 2 200 200> <&kscan0 2 3 300 200> <&kscan0 2 4 400 200> <&kscan0 2 5 500 200>
                /* 右手側 メイン (X=700から) */
                <&kscan0 0 6 700   0> <&kscan0 0 7 800   0> <&kscan0 0 8 900   0> <&kscan0 0 9 1000  0> <&kscan0 0 10 1100  0>
                <&kscan0 1 6 700 100> <&kscan0 1 7 800 100> <&kscan0 1 8 900 100> <&kscan0 1 9 1000 100> <&kscan0 1 10 1100 100>
                <&kscan0 2 6 700 200> <&kscan0 2 7 800 200> <&kscan0 2 8 900 200> <&kscan0 2 9 1000 200> <&kscan0 2 10 1100 200>
                /* 左手親指 */
                                      <&kscan0 3 4 400 300> <&kscan0 3 5 500 300>
                /* 右手親指 */
                <&kscan0 3 6 700 300> <&kscan0 3 7 800 300>
            >;
        };
    };
};