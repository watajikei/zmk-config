/*
 * 37keys2026.dtsi
 * 最新の ZMK main 仕様（keys位置属性・mapプロパティ・PULL_DOWNフラグ）に完全準拠した定義ファイル
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi> /* ★ZMK Studio のキー配置定義に必要なヘッダーをインクルード */

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,physical-layout = &default_layout;
    };

    /* 物理配列（左20キー、右17キー）とキーマップを紐解くマトリックス定義 */
    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <12>; // 左右全体の最大列数 (左6列 + 右6列のオフセット)
        rows = <4>;     // 行数 (D0〜D3の計4行)

        map = <
            /* ----------- 左手側 (20キー) ----------- */     /* ------- 右手側 (17キー) ------- */
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)     RC(0,6) RC(0,7) RC(0,8) RC(0,9) RC(0,10)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
                                            RC(3,4) RC(3,5)     RC(3,6) RC(3,7)
        >;
    };

    /* ★ZMK Studio の安全アサーションを通過させ、画面上にグリッド表示するための物理レイアウト定義 */
    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Default Layout";
        transform = <&default_transform>;
        kscan = <&kscan0>;

        /* 左右合計37キーの物理座標（1キーあたり幅100×高さ100、左右の間に少し隙間を配置） */
        keys
            = <&key_physical_attrs 100 100    0    0 0 0 0> // 1行目・左手6キー
            , <&key_physical_attrs 100 100  100    0 0 0 0>
            , <&key_physical_attrs 100 100  200    0 0 0 0>
            , <&key_physical_attrs 100 100  300    0 0 0 0>
            , <&key_physical_attrs 100 100  400    0 0 0 0>
            , <&key_physical_attrs 100 100  500    0 0 0 0>
            , <&key_physical_attrs 100 100  700    0 0 0 0> // 1行目・右手5キー
            , <&key_physical_attrs 100 100  800    0 0 0 0>
            , <&key_physical_attrs 100 100  900    0 0 0 0>
            , <&key_physical_attrs 100 100 1000    0 0 0 0>
            , <&key_physical_attrs 100 100 1100    0 0 0 0>

            , <&key_physical_attrs 100 100    0  100 0 0 0> // 2行目・左手6キー
            , <&key_physical_attrs 100 100  100  100 0 0 0>
            , <&key_physical_attrs 100 100  200  100 0 0 0>
            , <&key_physical_attrs 100 100  300  100 0 0 0>
            , <&key_physical_attrs 100 100  400  100 0 0 0>
            , <&key_physical_attrs 100 100  500  100 0 0 0>
            , <&key_physical_attrs 100 100  700  100 0 0 0> // 2行目・右手5キー
            , <&key_physical_attrs 100 100  800  100 0 0 0>
            , <&key_physical_attrs 100 100  900  100 0 0 0>
            , <&key_physical_attrs 100 100 1000  100 0 0 0>
            , <&key_physical_attrs 100 100 1100  100 0 0 0>

            , <&key_physical_attrs 100 100    0  200 0 0 0> // 3行目・左手6キー
            , <&key_physical_attrs 100 100  100  200 0 0 0>
            , <&key_physical_attrs 100 100  200  200 0 0 0>
            , <&key_physical_attrs 100 100  300  200 0 0 0>
            , <&key_physical_attrs 100 100  400  200 0 0 0>
            , <&key_physical_attrs 100 100  500  200 0 0 0>
            , <&key_physical_attrs 100 100  700  200 0 0 0> // 3行目・右手5キー
            , <&key_physical_attrs 100 100  800  200 0 0 0>
            , <&key_physical_attrs 100 100  900  200 0 0 0>
            , <&key_physical_attrs 100 100 1000  200 0 0 0>
            , <&key_physical_attrs 100 100 1100  200 0 0 0>

            , <&key_physical_attrs 100 100  400  300 0 0 0> // 親指行・左手2キー
            , <&key_physical_attrs 100 100  500  300 0 0 0>
            , <&key_physical_attrs 100 100  700  300 0 0 0> // 親指行・右手2キー
            , <&key_physical_attrs 100 100  800  300 0 0 0>
            ;
    };

    /* 物理的なピンのスキャン方法の設定 */
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "row2col";
        wakeup-source;

        /* 行（出力側）のピンアサイン：D0〜D3 */
        row-gpios
            = <&xiao_d 0 GPIO_ACTIVE_HIGH>
            , <&xiao_d 1 GPIO_ACTIVE_HIGH>
            , <&xiao_d 2 GPIO_ACTIVE_HIGH>
            , <&xiao_d 3 GPIO_ACTIVE_HIGH>
            ;

        /* 列（入力側）のピンアサイン：D4〜D9。PULL_DOWNを明示して電位の浮遊（混線）を完全に防止 */
        col-gpios
            = <&xiao_d 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
    };
};